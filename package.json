{
  "name": "ai-studio-applet",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "lint:types": "tsc --noEmit",
    "test": "vitest run",
    "test:e2e": "node scripts/run-playwright-e2e.mjs",
    "test:e2e:playwright": "playwright test",
    "test:watch": "vitest",
    "clean": "next clean",
    "docker:dev": "docker compose up --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f frontend",
    "docker:build": "docker build --target runner -t starterkit-frontend:local .",
    "docker:typecheck": "docker compose exec -T frontend pnpm run lint:types",
    "docker:lint": "docker compose exec -T frontend pnpm run lint",
    "docker:test": "docker compose exec -T frontend pnpm test"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "motion": "^12.42.2",
    "next": "^16.2.10",
    "postcss": "^8.5.16",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.1.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^9.39.1",
    "eslint-config-next": "^16.2.10",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4.3.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
